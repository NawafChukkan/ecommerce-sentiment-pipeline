APP_NAME=E-Commerce Sentiment & Product Life Cycles
APP_ENV=local
DATABASE_URL=postgresql://ecom_user:ecom_password@postgres:5432/ecom_sentiment

POSTGRES_DB=ecom_sentiment
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=ecom_password

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

BLOB_ENDPOINT=http://minio:9000
BLOB_ACCESS_KEY=minioadmin
BLOB_SECRET_KEY=minioadmin123
BLOB_REGION=us-east-1
BLOB_BUCKET=ecom-sentiment-raw
BLOB_RAW_PREFIX=source
BLOB_USE_SSL=false

SEED_PROFILE=demo
SEED_TARGET_SIZE_GB=1.5
SPARK_MASTER_URL=local[*]
RAW_DATA_DIR=/app/data/raw
SYNC_DATA_DIR=/app/data/synced

